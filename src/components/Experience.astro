---
import type { SiteData } from "../types/site";
import Section from "./Section.astro";
import { formatExperienceRange } from "../data/loadSite";

interface Props {
  data: SiteData;
}
const { data } = Astro.props;
---

<Section
  id="experience"
  title="Experience"
>
  <div class="grid-2">
    {
      data.experience.map((job) => (
        <article class="card experience-card">
          <h3>
            {job.title} — {job.company}
          </h3>
          <p class="card-meta">
            {job.location} · {formatExperienceRange(job.start, job.end)}
          </p>
          {job.summary && <p class="experience-summary">{job.summary}</p>}
          {job.stack && job.stack.length > 0 && (
            <div class="chips experience-stack">
              {job.stack.map((s) => (
                <span class="chip chip-sm">{s}</span>
              ))}
            </div>
          )}
          {job.bullets.length > 0 && (
            <details class="project-details">
              <summary class="project-details-summary">Details</summary>
              <ul class="project-bullet-list">
                {job.bullets.map((b) => (
                  <li>{b}</li>
                ))}
              </ul>
            </details>
          )}
        </article>
      ))
    }
  </div>
</Section>
