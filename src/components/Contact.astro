---
import type { SiteData } from "../types/site";
import Section from "./Section.astro";

interface Props {
  data: SiteData;
}
const { data } = Astro.props;
const { contact, location } = data;
const address = `${location.city}, ${location.country}, ${location.postal.replace(/\s+/g, "")}`;
---

<Section
  id="contact"
  title="Contact"
>
  <div class="contact-grid">
    <div class="card">
      <h3 style="margin-top: 0;">Reach me</h3>
      <p class="card-meta">{address}</p>
      <div class="contact-actions">
        <a class="btn btn-primary" href={`mailto:${contact.email}`}>
          {contact.email}
        </a>
        <a class="btn" href={`tel:${contact.phone.replace(/\s/g, "")}`}>{contact.phone}</a>
        <a class="btn" href={data.social.linkedin} target="_blank" rel="noopener noreferrer">
          LinkedIn
        </a>
      </div>
    </div>
  </div>
</Section>
