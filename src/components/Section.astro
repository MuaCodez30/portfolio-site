---
interface Props {
  id: string;
  title: string;
  intro?: string;
  class?: string;
}
const { id, title, intro, class: className = "" } = Astro.props;
---

<section class={`section ${className}`.trim()} id={id}>
  <div class="wrap">
    <h2 class="section-title">{title}</h2>
    {intro && <p class="section-intro">{intro}</p>}
    <slot />
  </div>
</section>
