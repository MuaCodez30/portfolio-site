---
import type { SiteData } from "../types/site";
import Section from "./Section.astro";
import ProjectCard from "./ProjectCard.astro";

interface Props {
  data: SiteData;
}
const { data } = Astro.props;
const byKind = (k: string) => data.projects.filter((p) => p.kind === k);
const featured = byKind("featured");
const course = byKind("course");
const archive = byKind("archive");
const leadershipArchive = archive.filter(
  (p) =>
    p.badge_label === "Community" ||
    p.badge_label === "Business" ||
    /hackathon|leadership|social responsibility|fenty/i.test(p.name),
);
const technicalArchive = archive.filter((p) => !leadershipArchive.includes(p));
const carouselProjects = [...course, ...technicalArchive, ...leadershipArchive].sort((a, b) => {
  const priorityName = "Azerbaijani news classification (TF–IDF)";
  if (a.name === priorityName && b.name !== priorityName) return -1;
  if (b.name === priorityName && a.name !== priorityName) return 1;
  const ao = Number(a.order ?? 0);
  const bo = Number(b.order ?? 0);
  if (ao !== bo) return ao - bo;
  return (a.date ?? "").localeCompare(b.date ?? "");
});
const highlightSummaries: Record<string, string> = {
  "Deepfake detection pipeline (video-level)":
    "Built a video-level deepfake detector with ResNet50 embeddings and classical ML models, focusing on temporal inconsistencies instead of static artifacts.",
  "Diabetes prediction with MLflow":
    "Delivered an end-to-end diabetes prediction workflow with MLflow tracking, model comparison, and reproducible experiment runs.",
  "Azerbaijani news classification (TF–IDF)":
    "Implemented multi-class Azerbaijani news classification with structured preprocessing, TF-IDF extraction, and model evaluation.",
  "Large-scale Cover_Type modeling":
    "Modeled forest cover type on a large dataset using scalable preprocessing and ensemble-focused optimization.",
};
const highlightDetailsNames = new Set([
  "Deepfake detection pipeline (video-level)",
  "Diabetes prediction with MLflow",
]);
---

<Section
  id="work"
  title="Featured projects"
>
  {
    featured.length > 0 && (
      <>
        <h3 class="subsection-title">Highlights</h3>
        <div class="projects-grid">
          {featured.map((p) => (
            <article class="card project-card featured-ml-card" tabindex="0">
              <h3>{p.name}</h3>
              <p class="card-meta">{p.date}</p>
              <p class="project-summary">
                {highlightSummaries[p.name] ?? p.lede}
              </p>
              {p.stack && p.stack.length > 0 && (
                <div class="chips project-stack">
                  {p.stack.map((s) => (
                    <span class="chip chip-sm">{s}</span>
                  ))}
                </div>
              )}
              {highlightDetailsNames.has(p.name) && p.bullets.length > 0 && (
                <details class="project-details">
                  <summary class="project-details-summary">Details</summary>
                  <ul class="project-bullet-list">
                    {p.bullets.map((b) => (
                      <li>{b}</li>
                    ))}
                  </ul>
                </details>
              )}
            </article>
          ))}
        </div>
      </>
    )
  }
  {
    carouselProjects.length > 0 && (
      <>
        <h3 class="subsection-title">Other projects</h3>
        <div class="mobile-projects-list">
          {carouselProjects.map((p) => (
            <ProjectCard project={p} compact={true} />
          ))}
        </div>
        <div
          class="coursework-carousel"
          data-coursework-carousel
          tabindex="0"
          role="region"
          aria-roledescription="carousel"
          aria-label="Other projects carousel"
        >
          <button
            type="button"
            class="carousel-nav carousel-prev"
            aria-label="Previous project"
          >
            <span aria-hidden="true">‹</span>
          </button>
          <div class="carousel-viewport">
            <div class="carousel-track" data-carousel-track>
              {carouselProjects.map((p) => (
                <div class="carousel-slide" data-carousel-slide>
                  <ProjectCard project={p} />
                </div>
              ))}
            </div>
          </div>
          <button
            type="button"
            class="carousel-nav carousel-next"
            aria-label="Next project"
          >
            <span aria-hidden="true">›</span>
          </button>
          <div class="carousel-dots" data-carousel-dots></div>
        </div>
        <script is:inline>
          (function () {
            function boot() {
              var root = document.querySelector("[data-coursework-carousel]");
              if (!root) return;

              var track = root.querySelector("[data-carousel-track]");
              var viewport = root.querySelector(".carousel-viewport");
              var slides = root.querySelectorAll("[data-carousel-slide]");
              var dotsHost = root.querySelector("[data-carousel-dots]");
              var prevBtn = root.querySelector(".carousel-prev");
              var nextBtn = root.querySelector(".carousel-next");
              var n = slides.length;
              var index = 0;
              var reduceMotion = window.matchMedia(
                "(prefers-reduced-motion: reduce)",
              ).matches;

              dotsHost.innerHTML = "";
              for (var d = 0; d < n; d++) {
                var dot = document.createElement("button");
                dot.type = "button";
                dot.className = "carousel-dot" + (d === 0 ? " is-active" : "");
                dot.setAttribute("aria-label", "Show project " + (d + 1));
                dot.setAttribute("data-carousel-index", String(d));
                dotsHost.appendChild(dot);
              }

              function slideWidth() {
                return viewport.getBoundingClientRect().width;
              }

              function layout() {
                var w = slideWidth();
                for (var s = 0; s < slides.length; s++) {
                  slides[s].style.flex = "0 0 " + w + "px";
                  slides[s].style.width = w + "px";
                }
              }

              function updateDots() {
                var dots = dotsHost.querySelectorAll(".carousel-dot");
                for (var j = 0; j < dots.length; j++) {
                  dots[j].classList.toggle("is-active", j === index);
                }
              }

              function go(to) {
                index = ((to % n) + n) % n;
                var w = slideWidth();
                var offset = -index * w;
                track.style.transform = "translate3d(" + offset + "px,0,0)";
                track.style.transition = reduceMotion
                  ? "none"
                  : "transform 0.35s ease";
                updateDots();
                root.setAttribute(
                  "aria-label",
                  "Other projects carousel, slide " + (index + 1) + " of " + n,
                );
              }

              layout();
              go(index);

              prevBtn.addEventListener("click", function () {
                go(index - 1);
              });
              nextBtn.addEventListener("click", function () {
                go(index + 1);
              });
              dotsHost.addEventListener("click", function (e) {
                var t = e.target;
                if (t && t.getAttribute("data-carousel-index") != null) {
                  go(+t.getAttribute("data-carousel-index"));
                }
              });

              root.addEventListener("keydown", function (e) {
                if (e.key === "ArrowLeft") {
                  go(index - 1);
                  e.preventDefault();
                } else if (e.key === "ArrowRight") {
                  go(index + 1);
                  e.preventDefault();
                }
              });

              window.addEventListener("resize", function () {
                layout();
                go(index);
              });
            }

            if (document.readyState === "loading") {
              document.addEventListener("DOMContentLoaded", boot);
            } else {
              boot();
            }
          })();
        </script>
      </>
    )
  }
</Section>
